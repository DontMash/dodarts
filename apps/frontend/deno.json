    "@fontsource-variable/inter": "npm:@fontsource-variable/inter@^5.2.8",
    "@fontsource-variable/roboto-slab": "npm:@fontsource-variable/roboto-slab@^5.2.8",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@orpc/client": "npm:@orpc/client@^1.14.3",
    "@tabler/icons-react": "npm:@tabler/icons-react@^3.44.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "@tanstack/devtools-vite": "npm:@tanstack/devtools-vite@^0.6.0",
    "@tanstack/react-devtools": "npm:@tanstack/react-devtools@^0.10.0",
    "@tanstack/react-router": "npm:@tanstack/react-router@^1.167.4",
    "@tanstack/react-router-devtools": "npm:@tanstack/react-router-devtools@^1.166.9",
    "@tanstack/react-start": "npm:@tanstack/react-start@^1.166.15",
