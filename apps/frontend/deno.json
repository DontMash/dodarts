    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "clsx": "npm:clsx@^2.1.1",
    "react": "npm:react@^19.2.4",
    "react-dom": "npm:react-dom@^19.2.4",
    "shadcn": "npm:shadcn@^4.8.0",
    "tailwind-merge": "npm:tailwind-merge@^3.6.0",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "vite": "npm:vite@^7.3.1"
  },
  "tasks": {
    "dev": "deno run -A npm:vite dev",
    "build": "deno run -A vite build",
    "preview": "deno run -A vite preview"
