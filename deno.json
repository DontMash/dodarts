{
  "workspace": ["apps/*", "packages/*"],
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.18"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "test": "deno test --allow-write --allow-read --allow-env --allow-ffi --env=.env.test",
    "test:coverage": "deno task test --coverage",
    "coverage": "deno coverage",
    "verify": "deno fmt && deno check && deno lint && deno task test:coverage"
  },
  "fmt": {
    "exclude": [".opencode"]
  },
  "lint": {
    "rules": {
      "exclude": ["no-slow-types"]
    }
  }
}
